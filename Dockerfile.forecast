FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir fastapi "uvicorn[standard]" torch transformers

COPY forecast_service.py ./

EXPOSE 8080

CMD ["sh", "-c", "uvicorn forecast_service:app --host 0.0.0.0 --port ${PORT:-8080}"]
